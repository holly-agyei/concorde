# Concorde local configuration. Keep real values in .env only.

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

AGENT_PHONE_API_KEY=
AGENT_PHONE_AGENT_ID=
AGENT_PHONE_NUMBER_ID=
AGENT_PHONE_PUBLIC_NUMBER=
AGENT_PHONE_WEBHOOK_SECRET=
# Dev-only: set to 1 to bypass AgentPhone signature verification when testing
# the /webhook/agentphone endpoint locally (e.g. via curl, ngrok, or
# scripts/test_agentphone_voice.py). Leave empty/0 in any shared environment.
AGENT_PHONE_SKIP_VERIFY=0

MOSS_PROJECT_ID=
MOSS_PROJECT_KEY=
MOSS_INDEX_NAME=concorde-demo

# Walmart Browser Use text-first flow.
WALMART_MODE=browser
BROWSER_USE_API_KEY=
BROWSER_USE_DRY_RUN=0
BROWSER_USE_ALLOW_SAVE=0
BROWSER_USE_HTTP_TIMEOUT=60
BROWSER_USE_KEEP_ALIVE=1
BROWSER_USE_ENABLE_RECORDING=1
BROWSER_USE_MAX_COST_USD=2
BROWSER_USE_WORKSPACE_ID=
BROWSER_USE_MODEL=
WALMART_BROWSER_PROFILE_ID=

# Optional Browser Use sensitive data. Prefer a logged-in Browser Use profile.
WALMART_EMAIL=
WALMART_PASSWORD=
WALMART_PHONE=
WALMART_ZIP_CODE=

# DoorDash visible local Chrome flow. This prepares or edits a cart only; checkout is blocked.
DOORDASH_BROWSER_PROFILE_ID=Default
DOORDASH_CHROME_USER_DATA_DIR=
DOORDASH_COPY_DEFAULT_PROFILE=1
DOORDASH_AUTOMATION_PROFILE_DIR=
DOORDASH_LATITUDE=37.7749
DOORDASH_LONGITUDE=-122.4194
DOORDASH_DRY_RUN=0
DOORDASH_HEADLESS=0
DOORDASH_KEEP_BROWSER_OPEN=1
DOORDASH_BROWSER_HOLD_MS=15000
DOORDASH_BROWSER_SLOW_MO_MS=350

# Hackathon aliases also work if already present in a parent .env.
agent_phone_api_key=
gemini_api_key=
moss_api_key=
moss_project_key=
browser_use_api_key=
browser_user_key=
